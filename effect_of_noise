##pt 2: using the (modified) code to backproject
import numpy as np
import matplotlib.pyplot as plt
from skimage.io import imread
from skimage.color import rgb2gray
from skimage.transform import rotate, resize

# ----------------------------
# 1. Radon Transform
# ----------------------------
def radon_transform(image, steps):
    """Compute sinogram of the image."""
    n = image.shape[0]
    sinogram = np.zeros((n, steps), dtype=np.float64)
    for s in range(steps):
        rotated = rotate(image, -s * 180 / steps, resize=False, order=1, mode='constant')
        sinogram[:, s] = np.sum(rotated, axis=0)
    return sinogram

# ----------------------------
# 2. Pad Sinogram to Square
# ----------------------------
def sinogram_circle_to_square(sinogram):
    diagonal = int(np.ceil(np.sqrt(2) * sinogram.shape[0]))
    pad = diagonal - sinogram.shape[0]
    old_center = sinogram.shape[0] // 2
    new_center = diagonal // 2
    pad_before = new_center - old_center
    pad_width = ((pad_before, pad - pad_before), (0, 0))
    return np.pad(sinogram, pad_width, mode='constant', constant_values=0)

# ----------------------------
# 3. Filtered Backprojection
# ----------------------------
def iradon_transform(radon_image, theta, interpolation='linear'):
    output_size = radon_image.shape[0]
    radon_image = sinogram_circle_to_square(radon_image)
    th = np.deg2rad(theta)  # convert to radians

    # pad to next power of 2 for FFT
    proj_size_padded = max(64, int(2 ** np.ceil(np.log2(2 * radon_image.shape[0]))))
    pad_width = ((0, proj_size_padded - radon_image.shape[0]), (0, 0))
    img = np.pad(radon_image, pad_width, mode='constant', constant_values=0)

    # Fourier filtering (ramp filter)
    freqs = np.fft.fftfreq(proj_size_padded).reshape(-1, 1)
    ramp_filter = 2 * np.abs(freqs)
    projection_fft = np.fft.fft(img, axis=0) * ramp_filter
    radon_filtered = np.real(np.fft.ifft(projection_fft, axis=0))
    radon_filtered = radon_filtered[:radon_image.shape[0], :]

    # Backprojection
    reconstructed = np.zeros((output_size, output_size), dtype=np.float64)
    X, Y = np.mgrid[0:output_size, 0:output_size]
    xpr = X - output_size // 2
    ypr = Y - output_size // 2
    mid_index = radon_image.shape[0] // 2

    for i in range(len(theta)):
        t = ypr * np.cos(th[i]) - xpr * np.sin(th[i])
        x = np.arange(radon_filtered.shape[0]) - mid_index

        if interpolation == 'linear':
            backproj = np.interp(t, x, radon_filtered[:, i], left=0, right=0)
        else:
            from scipy.interpolate import interp1d
            interpolant = interp1d(x, radon_filtered[:, i], kind=interpolation,
                                   bounds_error=False, fill_value=0)
            backproj = interpolant(t)
        reconstructed += backproj

    # Mask outside circle
    radius = output_size // 2
    mask = (xpr**2 + ypr**2) <= radius**2
    reconstructed[~mask] = 0

    # Normalize
    return reconstructed * np.pi / (2 * len(th))

# ----------------------------
# 4. Main
# ----------------------------
# Load image
results = {}

for name, noisy_img in [('Original', phantom),
                        ('Poisson', poisson_noise),
                        ('Gaussian', gaussian_noise),
                        ('S&P', sp_noise),
                        ('Speckle', speckle_noise)]:

# Radon Transform
    steps = 220
    sinogram = radon_transform(noisy_img, steps)

    # 2) FBP reconstruction
    theta = np.linspace(0., 180., steps, endpoint=False)
    reconstruction_fbp = iradon_transform(sinogram, theta=theta, interpolation='cubic')

# Store results
    results[name] = {
        'noisy': noisy_img,
        'sinogram': sinogram,
        'reconstruction': reconstruction_fbp
    }


# ----------------------------
# 5. save images
# ----------------------------
for name, data in results.items():
# Save sinogram (normalize to 0-255)
    sinogram_normalized = (data['sinogram'] - data['sinogram'].min()) / (data['sinogram'].max() - data['sinogram'].min())
    sinogram_img = (sinogram_normalized * 255).astype(np.uint8)
    imsave(f'{name}_sinogram.png', sinogram_img)

# Save reconstruction (normalize to 0-255)
    reconstruction_normalized = (data['reconstruction'] - data['reconstruction'].min()) / (data['reconstruction'].max() - data['reconstruction'].min())
    reconstruction_img = (reconstruction_normalized * 255).astype(np.uint8)
    imsave(f'{name}_reconstruction.png', reconstruction_img)

# ----------------------------
# 6. Plot results
# ----------------------------
fig, axes = plt.subplots(5, 3, figsize=(15, 20))

for idx, (name, data) in enumerate(results.items()):
    # Noisy
    axes[idx, 0].imshow(data['noisy'], cmap='gray')
    axes[idx, 0].set_title(f'{name} - Noisy')
    axes[idx, 0].axis('off')

    # Sinogram
    axes[idx, 1].imshow(data['sinogram'], cmap='gray', aspect='auto')
    axes[idx, 1].set_title(f'{name} - Sinogram')
    axes[idx, 1].set_xlabel('Projection angle')
    axes[idx, 1].set_ylabel('Detector position')

    # Reconstruction
    axes[idx, 2].imshow(data['reconstruction'], cmap='gray')
    axes[idx, 2].set_title(f'{name} - FBP Reconstruction')
    axes[idx, 2].axis('off')

plt.tight_layout()
plt.show()


