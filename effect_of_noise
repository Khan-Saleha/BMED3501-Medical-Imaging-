## part 1: noise introduction

import numpy as np
import matplotlib.pyplot as plt
from skimage import io 
from skimage.color import rgb2gray
from skimage.util import random_noise
from skimage.transform import rotate, resize
from sklearn.metrics import mean_squared_error

phantom = io.imread('shepplogan.png')  # adjust path/format
if phantom.ndim == 3:
    phantom = rgb2gray(phantom)
phantom = resize(phantom, (220, 220), anti_aliasing=True)

#Add Noise
phantom_mean = np.mean(phantom)
poisson_scalar = phantom_mean / 0.01
# Apply custom poisson scaling
poisson_noise = np.random.poisson(phantom * poisson_scalar) / poisson_scalar
# Clip to valid image range [0, 1] just like random_noise does
poisson_noise = np.clip(poisson_noise, 0.0, 1.0)

gaussian_noise = random_noise(phantom, mode='gaussian', var=0.01)
sp_noise = random_noise(phantom, mode='s&p', amount=0.02)
speckle_noise = random_noise(phantom, mode='speckle', var=0.2)

#Plot
fig, axes = plt.subplots(1, 5, figsize=(15, 5))
axes[0].imshow(phantom, cmap='gray')
axes[0].set_title('Original Phantom')
axes[1].imshow(poisson_noise, cmap='gray')
axes[1].set_title('Poisson Noise')
axes[2].imshow(gaussian_noise, cmap='gray')
axes[2].set_title('Gaussian Noise')
axes[3].imshow(sp_noise, cmap='gray')
axes[3].set_title('Salt & Pepper Noise')
axes[4].imshow(speckle_noise, cmap='gray')
axes[4].set_title('Speckle Noise')

plt.show()

print("MSE Comparison:")
print(f"Gaussian MSE:  {mean_squared_error(phantom, gaussian_noise):.4f}")
print(f"S&P MSE:       {mean_squared_error(phantom, sp_noise):.4f}")
print(f"Speckle MSE:   {mean_squared_error(phantom, speckle_noise):.4f}")
print(f"Poisson MSE:   {mean_squared_error(phantom, poisson_noise):.4f}")

# save images
from skimage.io import imsave
imsave('poisson_noise.png', (poisson_noise * 255).astype(np.uint8))
imsave('gaussian_noise.png', (gaussian_noise * 255).astype(np.uint8))
imsave('sp_noise.png', (sp_noise * 255).astype(np.uint8))
imsave('speckle_noise.png', (speckle_noise * 255).astype(np.uint8))

